# Pipeline output (per-RFE artifacts)
.artifacts/

# Parked ideas (local planning, not tracked)
future.md
tmp/
reports/

# Decision artifacts (generated by decision-kit, not source)
.decisions/

# Fetched context (downloaded at runtime)
.context/

# Credentials
.env/

# Node (trailing slash: ignores real node_modules dirs but NOT the root symlink,
# which is committed for ESM module resolution — see eval README)
node_modules/
package-lock.json

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
build/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test fixtures — oversized files (>20MB) excluded from git
.claude/skills/eval/tests/fixtures/images/oversized-test.png

# Eval harness integration (local testing only, not pushed)
.claude/skills/eval/eval-harness/
.claude/skills/eval/eval-optimize-mlflow/

# Migration guide (transitional doc for UXD AI Helpers integration, not pushed)
.claude/skills/eval/MIGRATION.md

# Stray Playwright scripts from eval runs (should be in .artifacts/)
.claude/skills/eval/journey-test-*.mjs
.claude/skills/eval/persona-walkthrough-*.mjs

# Run metrics (generated per-run, not source)
.artifacts/**/run-metrics.json

# MLflow local tracking (may be created at project root or eval-harness root)
mlflow.db
mlruns/

# Eval harness run outputs (created by /eval-run)
eval/runs/

# Ad-hoc scripts and planning docs (local-only, not pipeline code)
.claude/skills/eval/PLAN-*.md
.claude/skills/eval/scripts/query-model-costs.py
.claude/skills/eval/scripts/mlflow-trace-eval.py

# Cursor workspace state
.cursor/

# Presentation drafts and personal notes
docs/drafts/

# OS
.DS_Store
Thumbs.db